# ============================================================
# Stock Insight Agent — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Inference (Groq) ---
# Used by core_nlp.py for sentiment analysis and event classification (batch pipeline).
# Get your key at: https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# --- Google AI (optional) ---
# Used if you integrate Google Generative AI features.
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your_google_api_key_here"

# --- HuggingFace (optional) ---
# Used for any HuggingFace model inference.
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN="your_huggingface_token_here"

# --- Neo4j Knowledge Graph ---
# Used by worker.py for competitor relationship lookups.
# Get a free AuraDB instance at: https://neo4j.com/cloud/platform/aura-graph-database
NEO4J_URI="neo4j+s://your-instance-id.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your_neo4j_password_here"

# --- PostgreSQL (Supabase) ---
# Used to store and retrieve processed insights.
# IMPORTANT: Use Session Pooler (port 6543), not Direct Connection (port 5432),
# if your network is IPv4-only (most home networks).
# Find these in your Supabase project: Settings → Database → Connection Pooling
DB_HOST="aws-0-ap-south-1.pooler.supabase.com"
DB_PORT="6543"
DB_USER="postgres.your_project_ref"
DB_PASSWORD="your_supabase_db_password"
DB_NAME="postgres"
